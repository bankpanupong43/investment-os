generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Position ─────────────────────────────────────────────────────────────────

model Position {
  id         String    @id @default(cuid())
  ticker     String
  name       String
  sector     String?
  industry   String?
  assetClass String    @default("equity")
  shares     Float?
  avgCost    Float?
  entryDate  DateTime?
  status     String    @default("active") // active | closed | trimmed
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Snapshot fields — populated from portfolio tracking tools when share count / avg cost is unavailable
  currentValueUsd     Float?
  currentValueThb     Float?
  allocationPct       Float?   // % of total portfolio at snapshot date
  unrealizedReturnPct Float?   // unrealized gain/loss %
  costBasisUsd        Float?   // derived: currentValueUsd / (1 + unrealizedReturnPct)
  dataSource          String?  // origin of this data (e.g. "หุ้น.xlsx", "Dime app")
  confidence          String?  // high | medium | low
  snapshotDate        DateTime?

  thesis           Thesis?
  killConditions   KillCondition[]
  journalEntries   JournalEntry[]
  recommendations  Recommendation[]
  newsItems        NewsItem[]
  earningsEvents   EarningsEvent[]
  thesisEvaluations ThesisEvaluation[]

  @@map("positions")
}

// ─── Thesis ───────────────────────────────────────────────────────────────────

model Thesis {
  id         String @id @default(cuid())
  positionId String @unique
  version    Int    @default(1) // increments on each formal revision

  // Core thesis text — immutable original, evolving assessment
  originalThesis    String  // WHY you bought; never edited
  currentAssessment String? // evolving view of thesis status

  // Structured components stored as JSON arrays (see TypeScript types)
  keyAssumptions   String @default("[]") // ThesisKeyAssumption[]
  expectedOutcomes String @default("[]") // ExpectedOutcome[]
  risks            String @default("[]") // ThesisRisk[]

  // Time frame
  holdingPeriod       String? // human-readable: "3-5 years"
  holdingPeriodMonths Int?    // for calculations: 36-60

  // Confidence at entry time (1-10) — set once, never changed
  // Use ThesisEvaluation.overallScore for ongoing strength
  entryConfidence Int @default(7)

  // Current health (updated by agents)
  healthStatus   String    @default("intact") // intact | weakening | broken | monitoring
  healthScore    Int       @default(7)        // 0-10 current health, updated each evaluation
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  position    Position           @relation(fields: [positionId], references: [id], onDelete: Cascade)
  updates     ThesisUpdate[]     // incremental observations
  versions    ThesisVersion[]    // full snapshots on formal revisions
  evaluations ThesisEvaluation[] // AI scoring records

  @@map("theses")
}

// ─── ThesisVersion ────────────────────────────────────────────────────────────
// Full snapshot of thesis state at the time of each formal revision.
// Version 1 = initial thesis at entry. Version 2+ = revised theses.
// The original `originalThesis` on the Thesis model is immutable;
// revisions live here as complete replacements of all structured components.

model ThesisVersion {
  id       String @id @default(cuid())
  thesisId String
  version  Int

  // Complete thesis state at this version
  thesisText       String
  keyAssumptions   String @default("[]") // ThesisKeyAssumption[]
  expectedOutcomes String @default("[]") // ExpectedOutcome[]
  risks            String @default("[]") // ThesisRisk[]
  holdingPeriod    String?
  entryConfidence  Int

  // Why was this revision made?
  revisionReason String  // required — forces you to articulate why the thesis changed
  revisedBy      String  @default("manual") // manual | ai

  createdAt DateTime @default(now())

  thesis Thesis @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@unique([thesisId, version])
  @@map("thesis_versions")
}

// ─── ThesisUpdate ─────────────────────────────────────────────────────────────
// Incremental observations — news, earnings, macro events that are
// relevant but don't constitute a formal thesis revision.

model ThesisUpdate {
  id          String   @id @default(cuid())
  thesisId    String
  updateType  String   // confirmation | weakening | neutral | breaking
  content     String
  triggeredBy String?  // earnings | news | manual | macro | price_action
  sourceUrl   String?
  createdAt   DateTime @default(now())

  thesis Thesis @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@map("thesis_updates")
}

// ─── ThesisEvaluation ─────────────────────────────────────────────────────────
// AI scoring record. Created each time an agent evaluates the thesis.
// Stores the full evidence-based assessment of each component.

model ThesisEvaluation {
  id         String @id @default(cuid())
  thesisId   String
  positionId String

  // Component scores (0.0–10.0)
  // Each is the average of individual item scores within that component.
  assumptionsScore Float // how well key assumptions are holding
  outcomesScore    Float // on track for expected outcomes
  riskScore        Float // risks NOT materializing (10 = none materialized)
  integrityScore   Float // AI judgment: is the core thesis still coherent?

  // Weighted composite
  // overallScore = assumptions×0.35 + outcomes×0.30 + risk×0.20 + integrity×0.15
  overallScore Float

  // Detailed per-item assessments (JSON arrays — see TypeScript types)
  assumptionAssessments String // AssumptionAssessment[]
  outcomeAssessments    String // OutcomeAssessment[]
  riskAssessments       String // RiskAssessment[]

  // Narrative
  strengths            String  // what is confirmed and going well
  concerns             String  // what is changing or at risk
  scoreRationale       String  // brief explanation of overall score

  // Recommendation output
  recommendation       String  // hold | add | reduce | sell | watch
  recommendationReason String
  thesisReference      String  // quote from originalThesis that informs this recommendation

  evaluatedBy String  @default("ai") // ai | manual
  modelUsed   String? // which AI model, e.g. claude-opus-4-8
  createdAt   DateTime @default(now())

  thesis   Thesis   @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@map("thesis_evaluations")
}

// ─── KillCondition ────────────────────────────────────────────────────────────

model KillCondition {
  id            String    @id @default(cuid())
  positionId    String
  conditionType String    // quantitative | qualitative
  description   String
  metric        String?   // e.g. "azure_growth_rate", "market_share"
  operator      String?   // lt | gt | eq | lte | gte | drops_below
  threshold     Float?
  status        String    @default("active") // active | triggered | dismissed
  triggeredAt   DateTime?
  triggeredNote String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  position        Position         @relation(fields: [positionId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]

  @@map("kill_conditions")
}

// ─── JournalEntry ─────────────────────────────────────────────────────────────

model JournalEntry {
  id         String   @id @default(cuid())
  positionId String?
  entryType  String   // buy_rationale | thesis_update | decision | observation | earnings_note | macro | evaluation
  content    String
  createdAt  DateTime @default(now())

  position Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@map("journal_entries")
}

// ─── Recommendation ───────────────────────────────────────────────────────────

model Recommendation {
  id              String    @id @default(cuid())
  positionId      String
  action          String    // hold | add | reduce | sell | watch
  reasoning       String
  thesisReference String    // NON-NULLABLE: must quote the original thesis
  killConditionId String?
  evaluationId    String?   // link to the ThesisEvaluation that generated this
  confidence      Int?      // 1-5
  urgency         String    @default("low") // low | medium | high | critical
  status          String    @default("pending") // pending | acknowledged | acted | dismissed
  acknowledgedAt  DateTime?
  createdAt       DateTime  @default(now())

  position      Position       @relation(fields: [positionId], references: [id], onDelete: Cascade)
  killCondition KillCondition? @relation(fields: [killConditionId], references: [id])

  @@map("recommendations")
}

// ─── NewsItem ─────────────────────────────────────────────────────────────────

model NewsItem {
  id                 String    @id @default(cuid())
  positionId         String?
  ticker             String
  headline           String
  content            String?
  source             String?
  url                String?
  sentiment          String?   // positive | negative | neutral
  thesisRelevance    String?   // high | medium | low | none
  relevanceReasoning String?
  publishedAt        DateTime?
  fetchedAt          DateTime  @default(now())

  position Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@map("news_items")
}

// ─── EarningsEvent ────────────────────────────────────────────────────────────

model EarningsEvent {
  id                    String    @id @default(cuid())
  positionId            String?
  ticker                String
  fiscalQuarter         Int?      // 1–4
  fiscalYear            Int?      // e.g. 2024
  fiscalPeriod          String?   // human-readable: "Q1 2024"
  reportDate            DateTime?
  epsActual             Float?
  epsEstimate           Float?
  revenueActual         Float?
  revenueEstimate       Float?
  guidanceSummary       String?
  transcript            String?   // full call transcript (if available)
  managementCommentary  String?   // extracted key management commentary
  keyMetrics            String?   // JSON: Record<string, string | number>
  thesisImpact          String?   // positive | negative | neutral | n/a
  thesisAssumptionsHit  String?   // JSON: {assumption: string, result: "met"|"missed"|"n/a"}[]
  killConditionsChecked String?   // JSON: {conditionId: string, triggered: boolean}[]
  createdAt             DateTime  @default(now())

  position Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@map("earnings_events")
}

// ─── Filing ───────────────────────────────────────────────────────────────────
// SEC EDGAR filings — 10-K, 10-Q, 8-K, 20-F

model Filing {
  id              String    @id @default(cuid())
  ticker          String
  filingType      String    // 10-K | 10-Q | 8-K | 20-F
  accessionNumber String    @unique
  filingDate      DateTime
  periodEndDate   DateTime?
  title           String    @default("")
  summary         String?   // AI-generated summary
  rawContent      String?   // full extracted text
  sourceUrl       String?
  createdAt       DateTime  @default(now())

  thesisImpacts ThesisImpactRecord[]

  @@index([ticker])
  @@index([ticker, filingType])
  @@map("filings")
}

// ─── ThesisImpactRecord ────────────────────────────────────────────────────────
// Thesis impact evaluation result for a specific filing.

model ThesisImpactRecord {
  id             String   @id @default(cuid())
  filingId       String
  ticker         String
  impactLevel    String   // intact | strengthened | weakened | kill_criteria_triggered
  impactedThesis String   // which thesis / thesis aspect is impacted
  reasoning      String   // why this impact was assessed
  evidenceIds    String   @default("[]") // JSON: string[] — references to fact IDs or filing excerpts
  createdAt      DateTime @default(now())

  filing Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([ticker])
  @@map("thesis_impact_records")
}

// ─── Watchlist ────────────────────────────────────────────────────────────────

model Watchlist {
  id               String   @id @default(cuid())
  ticker           String   @unique
  name             String?
  status           String   @default("watching") // watching | researching | high_conviction | rejected | owned
  interestReason   String
  notes            String?
  draftThesis      String?
  targetEntryPrice Float?
  addedAt          DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@map("watchlist")
}

// ─── TeamSession ──────────────────────────────────────────────────────────────
// Coordinates one full multi-agent analysis cycle.
// The Portfolio Manager orchestrates the session; each analyst posts a briefing;
// the PM reads all briefings and produces the final synthesis + decisions.

model TeamSession {
  id          String    @id @default(cuid())
  triggerType String    // morning_review | earnings_event | news_event | weekly_review | manual | idea_generation
  triggerNote String?   // human-readable description of what prompted this session
  tickers     String    @default("[]") // JSON: string[] of relevant tickers
  status      String    @default("running") // running | complete | failed

  // PM final output
  finalSynthesis   String?  // JSON: PortfolioManagerDecision
  decisionsCreated Int      @default(0)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  briefings AgentBriefing[]

  @@map("team_sessions")
}

// ─── AgentBriefing ────────────────────────────────────────────────────────────
// One agent's structured report for a session.
// Analysts write briefings; Portfolio Manager reads all of them.

model AgentBriefing {
  id        String   @id @default(cuid())
  sessionId String
  agentRole String   // portfolio_manager | thesis_analyst | news_analyst | earnings_analyst | risk_manager | idea_generator
  ticker    String?  // populated when briefing is position-specific
  report    String   // JSON typed report (see src/types/team.ts)
  summary   String   // 2-3 sentence plaintext summary for quick scanning
  createdAt DateTime @default(now())

  session TeamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("agent_briefings")
}

// ─── PortfolioSettings ────────────────────────────────────────────────────────
// Single-row config table for top-level portfolio parameters.

model PortfolioSettings {
  id              String   @id @default(cuid())
  label           String   @default("Main Portfolio")
  totalCapitalThb Float    // ฿1,300,000 — audited total invested capital
  totalCapitalUsd Float    // $39,816.22 at seed-time exchange rate
  exchangeRate    Float    // 32.65 THB/USD at seed time
  source          String?  // data provenance note
  updatedAt       DateTime @updatedAt

  @@map("portfolio_settings")
}

// ─── AllocationTarget ─────────────────────────────────────────────────────────
// Target allocation per ticker from the investment plan.
// Joined at runtime with Position snapshot data to compute gaps and rankings.

model AllocationTarget {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  targetPct Float    // 0–100, percentage of totalCapitalUsd
  targetUsd Float    // absolute USD target amount
  targetThb Float    // absolute THB target amount
  bucket    String   // growth | core | small | defensive | value
  priority  Int      // buy priority rank — lower = buy first
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("allocation_targets")
}

// ─── PortfolioReview ──────────────────────────────────────────────────────────
// Snapshot of a full portfolio review at a point in time.
// All section and card fields are JSON strings (SQLite has no native JSON type).

model PortfolioReview {
  id          String   @id @default(cuid())
  generatedAt DateTime @default(now())
  notes       String?

  // Section analysis — JSON strings
  portfolioSummary          String  // JSON: PortfolioSummary
  allocationAnalysis        String  // JSON: AllocationAnalysis
  thesisCoverageAnalysis    String  // JSON: ThesisCoverageAnalysis
  riskAnalysis              String  // JSON: RiskAnalysis
  cashAllocationReview      String  // JSON: CashAllocationReview
  watchlistPrioritization   String  // JSON: WatchlistPrioritization

  // AI review cards — JSON strings
  biggestRisk        String  // JSON: ReviewCard
  biggestOpportunity String  // JSON: ReviewCard
  mostUnderallocated String  // JSON: ReviewCard
  weakestThesis      String  // JSON: ReviewCard
  reviewsDue         String  // JSON: ReviewCard[]

  // Filing intelligence cards (Phase 5E)
  filingsRequiringReview String  @default("[]") // JSON: ReviewCard[]
  thesisAlerts           String  @default("[]") // JSON: ReviewCard[]
  newRisksDetected       String  @default("[]") // JSON: ReviewCard[]

  // Brain OS context that was active when this review was generated
  brainContextReport String? // JSON: BrainOSContext | null

  // Top 3 opportunities at review time
  topOpportunities String @default("[]") // JSON: OpportunityEntry[]

  @@map("portfolio_reviews")
}

// ─── Universe ─────────────────────────────────────────────────────────────────
// Master list of investable securities across all tiers.

model Universe {
  id           String   @id @default(cuid())
  ticker       String   @unique
  companyName  String
  exchange     String?
  sector       String?
  industry     String?
  marketCap    Float?   // USD millions
  universeTier String   // tier1 | tier2 | tier3 | tier4 | tier5
  country      String   @default("US")
  assetType    String   @default("equity") // equity | etf
  status       String   @default("active") // active | excluded | delisted
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fundamentals Fundamental?
  scores       UniverseScore[]

  @@map("universe")
}

// ─── Fundamental ──────────────────────────────────────────────────────────────
// Financial metrics for a universe entry. Updated by data ingestion.

model Fundamental {
  id                String   @id @default(cuid())
  universeId        String   @unique
  revenueGrowth     Float?   // YoY %
  epsGrowth         Float?   // YoY %
  grossMargin       Float?   // % (0-100)
  operatingMargin   Float?   // % (0-100)
  freeCashFlow      Float?   // USD millions
  debtToEquity      Float?
  roic              Float?   // % (0-100)
  sharesOutstanding Float?   // millions
  updatedAt         DateTime @updatedAt

  universe Universe @relation(fields: [universeId], references: [id], onDelete: Cascade)

  @@map("fundamentals")
}

// ─── UniverseScore ────────────────────────────────────────────────────────────
// Cached scoring output per universe entry. Latest record is the current score.

model UniverseScore {
  id                String   @id @default(cuid())
  universeId        String
  businessQuality   Float    // 0-100
  growth            Float    // 0-100
  financialStrength Float    // 0-100
  capitalAllocation Float    // 0-100
  valuation         Float    // 0-100 (placeholder until price data)
  totalScore        Float    // 0-100
  scoredAt          DateTime @default(now())

  universe Universe @relation(fields: [universeId], references: [id], onDelete: Cascade)

  @@map("universe_scores")
}

// ─── ResearchDossier ─────────────────────────────────────────────────────────
// AI-generated research dossier per universe entry.
// Overwritten on regeneration (one dossier per ticker at any time).

model ResearchDossier {
  id                  String   @id @default(cuid())
  ticker              String   @unique
  companyName         String   @default("")
  opportunityScore    Float    @default(0)
  companyScore        Float    @default(0)
  investmentSummary   String   @default("{}") // JSON: InvestmentSummary
  businessOverview    String   @default("{}") // JSON: BusinessOverview
  whyBuy              String   @default("[]") // JSON: WhyBuyReason[]
  risks               String   @default("{}") // JSON: RiskSections
  portfolioFit        String   @default("{}") // JSON: PortfolioFit
  thesisDraft         String   @default("{}") // JSON: ThesisDraft
  suggestedAllocation String   @default("{}") // JSON: SuggestedAllocation
  // Evidence layer (Phase 5D.5)
  facts               String   @default("[]") // JSON: FactItem[]
  interpretation      String   @default("[]") // JSON: InterpretationItem[]
  recommendation      String   @default("{}") // JSON: RecommendationSection
  evidenceSummary     String   @default("{}") // JSON: EvidenceSummary
  generatedAt         DateTime @default(now())

  @@index([opportunityScore])
  @@map("research_dossiers")
}

// ─── Evidence ─────────────────────────────────────────────────────────────────
// Normalized fact store — one record per fact per dossier generation.
// Enables querying evidence across tickers and auditing fact provenance.

model Evidence {
  id           String   @id @default(cuid())
  ticker       String
  factId       String   // matches FactItem.id in the dossier JSON (e.g. "MSFT_001")
  category     String   // Fundamentals | Portfolio | Opportunity | BrainContext | Research
  metric       String
  value        String
  numericValue Float?
  unit         String?
  source       String
  sourceDate   String?
  confidence   String   // high | medium | low
  createdAt    DateTime @default(now())

  @@index([ticker])
  @@index([ticker, metric])
  @@map("evidence")
}

// ─── OpportunityScore ────────────────────────────────────────────────────────
// Saved snapshot of opportunity scores for each universe entry.
// Latest record per ticker is the current score.

model OpportunityScore {
  id                   String   @id @default(cuid())
  ticker               String
  companyScore         Float
  allocationGapScore   Float
  diversificationScore Float
  watchlistScore       Float
  brainAlignmentScore  Float
  opportunityScore     Float
  reasoning            String   @default("{}") // JSON: OpportunityReasoning
  generatedAt          DateTime @default(now())

  @@index([ticker])
  @@index([opportunityScore])
  @@map("opportunity_scores")
}

// ─── IngestionLog ─────────────────────────────────────────────────────────────
// Audit trail for every data ingestion event (FMP, manual, seed).

model IngestionLog {
  id            String   @id @default(cuid())
  ticker        String
  source        String   // fmp | manual | seed
  status        String   // success | partial | failed | skipped
  fieldsUpdated String   @default("[]") // JSON: string[]
  fieldsMissing String   @default("[]") // JSON: string[]
  errorMessage  String?
  apiCallCount  Int      @default(0)
  durationMs    Int?
  createdAt     DateTime @default(now())

  @@map("ingestion_logs")
}

// ─── RecommendationFeedback ───────────────────────────────────────────────────
// User signal on a ticker recommendation — drives the learning layer.

model RecommendationFeedback {
  id           String   @id @default(cuid())
  ticker       String
  feedbackType String   // interested | not_interested | already_owned | disagree | researching
  notes        String?
  createdAt    DateTime @default(now())

  @@index([ticker])
  @@index([createdAt])
  @@map("recommendation_feedback")
}

// ─── Backup ───────────────────────────────────────────────────────────────────
// Audit record for every backup operation.

model Backup {
  id         String   @id @default(cuid())
  backupType String   // database | brain_os_export | full_snapshot
  filePath   String   // path relative to project root
  fileSize   Int      // bytes
  checksum   String   // SHA256
  metadata   String   @default("{}") // JSON: label, restore info, etc.
  createdAt  DateTime @default(now())

  @@index([backupType])
  @@map("backups")
}

// ─── Job ──────────────────────────────────────────────────────────────────────
// Audit record for every scheduled or manually triggered automation job.

model Job {
  id            String    @id @default(cuid())
  jobName       String    // backup | integrity_check | sec_filing_refresh | etc.
  status        String    @default("pending") // pending | running | completed | failed | skipped
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  durationMs    Int?
  resultSummary String?   // human-readable one-line result
  errorMessage  String?

  @@index([jobName])
  @@index([status])
  @@index([startedAt])
  @@map("jobs")
}

// ─── CommitteeSession ─────────────────────────────────────────────────────────
// Evidence-based investment committee debate — one session per ticker per run.
// All 5 member outputs are stored as JSON. Every claim must cite evidence IDs.

model CommitteeSession {
  id             String   @id @default(cuid())
  ticker         String
  companyName    String   @default("")
  sector         String?
  universeTier   String   @default("tier1")
  bullCase       String   // JSON: BullCase
  bearCase       String   // JSON: BearCase
  riskAssessment String   // JSON: RiskAssessment
  thesisAudit    String   // JSON: ThesisAudit
  finalDecision  String   // JSON: FinalDecision
  conviction     String   // Strong Buy | Buy | Watch | Hold | Pass
  createdAt      DateTime @default(now())

  @@index([ticker])
  @@index([conviction])
  @@map("committee_sessions")
}

// ─── Brief ────────────────────────────────────────────────────────────────────

model Brief {
  id          String    @id @default(cuid())
  briefType   String    // morning | weekly
  content     String    // markdown
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("briefs")
}

// ─── MorningBrief ─────────────────────────────────────────────────────────────
// Daily morning intelligence — one per calendar day.
// All section fields are JSON strings. Generated by morning-brief-engine.ts.

model MorningBrief {
  id                   String   @id @default(cuid())
  briefingDate         DateTime @unique  // date portion only; one per day
  marketRegime         String   // "Risk On" | "Neutral" | "Risk Off"
  marketRegimeEvidence String   @default("[]") // JSON: string[]
  macroSummary         String   @default("{}") // JSON: MacroSummary
  geopoliticalSummary  String   @default("{}") // JSON: GeopoliticalSummary
  technologySummary    String   @default("{}") // JSON: TechnologySummary
  portfolioImpact      String   @default("{}") // JSON: PortfolioImpact
  recommendedActions   String   @default("[]") // JSON: RecommendedAction[]
  generatedFromSources String   @default("{}") // JSON: {positions: n, filings: n, committee: n, ...}
  createdAt            DateTime @default(now())

  @@index([briefingDate])
  @@map("morning_briefs")
}

// ─── DiscoveryCandidate ───────────────────────────────────────────────────────
// Radar-surfaced investment ideas not yet in portfolio or watchlist.
// Refreshed nightly; one record per ticker (upserted on each run).

model DiscoveryCandidate {
  id              String    @id @default(cuid())
  ticker          String    @unique
  companyName     String
  marketCap       Float?    // USD millions
  category        String    // small_cap | mid_cap | large_cap | etf | special_situation
  discoveryReason String    // primary signal that surfaced this ticker
  radarScore      Float     // 0-100 composite score
  confidence      String    // high | medium | low
  themes          String    @default("[]") // JSON: string[] — matching discovery themes
  signals         String    @default("[]") // JSON: RadarSignal[] — all contributing signals
  sources         String    @default("[]") // JSON: string[] — which sources flagged this
  status          String    @default("active") // active | promoted | dismissed
  promotedAt      DateTime? // when user triggered dossier/committee from radar
  lastRefreshedAt DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([radarScore])
  @@index([category])
  @@index([status])
  @@map("discovery_candidates")
}

// ─── InvestmentThesis ─────────────────────────────────────────────────────────
// Human-authored decision-support record — one per ticker (position or watchlist).
// Separate from the agent-facing Thesis model (which is position-linked & AI-driven).

model InvestmentThesis {
  id              String    @id @default(cuid())
  ticker          String    @unique
  title           String
  thesis          String    // Core investment thesis — why you own or want to own this
  whyOwn          String    // One-paragraph ownership rationale
  risks           String    // Key risks in plain text
  killCriteria    String    // Concrete conditions that would cause an exit
  confidenceScore Int       @default(7)          // 1–10; 10 = highest conviction
  reviewFrequency String    @default("quarterly") // monthly | quarterly | annually
  lastReviewedAt  DateTime?
  status          String    @default("active")   // active | watchlist | closed
  isDraft         Boolean   @default(true)        // true = AI-generated draft, needs human review
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reviews ThesisReview[]

  @@map("investment_theses")
}

// ─── ThesisReview ─────────────────────────────────────────────────────────────
// Audit log of each time a thesis is reviewed or confidence is updated.

model ThesisReview {
  id                 String   @id @default(cuid())
  thesisId           String
  reviewType         String   // review_completed | confidence_changed
  previousConfidence Int?
  newConfidence      Int?
  notes              String?
  reviewedAt         DateTime @default(now())

  thesis InvestmentThesis @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@map("thesis_reviews")
}

// ─── PortfolioBlueprint ───────────────────────────────────────────────────────
// CIO-level portfolio construction blueprint — one per calendar day.
// All analysis sections are JSON strings. Generated by architect-engine.ts.

model PortfolioBlueprint {
  id            String   @id @default(cuid())
  blueprintDate DateTime @unique // date portion only; one per day

  marketRegime   String            // "Risk On" | "Neutral" | "Risk Off"
  regimeEvidence String @default("[]") // JSON: string[]

  // Target allocation % (regime-adaptive)
  growthAllocation        Float
  valueAllocation         Float
  largeCap                Float
  midCap                  Float
  smallCap                Float
  international           Float
  hedgeAllocation         Float
  cashAllocation          Float

  // Concentration rules
  maxPositions      Int   @default(20)
  maxSingleStockPct Float @default(10.0)
  maxSectorPct      Float @default(35.0)

  // Full analysis sections (JSON strings)
  gapAnalysis          String @default("[]") // JSON: GapItem[]
  capitalAllocation    String @default("{}") // JSON: CapitalAllocationPlan
  scenarioAnalysis     String @default("[]") // JSON: ScenarioResult[]
  cioAnswers           String @default("{}") // JSON: CIOAnswers
  reasoning            String // CIO synthesis narrative
  generatedFromSources String @default("{}") // JSON: source counts

  createdAt DateTime @default(now())

  @@index([blueprintDate])
  @@map("portfolio_blueprints")
}

// ─── MacroSnapshot ────────────────────────────────────────────────────────────
// Real macro data fetched from FRED (Federal Reserve Economic Data).
// One record per metric per release date. Updated by macro_ingestion job.

model MacroSnapshot {
  id          Int      @id @default(autoincrement())
  date        DateTime // observation date from FRED (e.g. 2025-04-01 for April CPI)
  metric      String   // "CPI" | "Core CPI" | "Fed Funds Rate" | "Unemployment" | "GDP Growth" | "10Y Treasury Yield" | "2Y Treasury Yield"
  value       Float
  source      String   // "FRED"
  releaseDate DateTime? // when this data point was ingested

  createdAt DateTime @default(now())

  @@unique([date, metric])
  @@index([metric])
  @@index([date])
  @@map("macro_snapshots")
}

// ─── MarketSnapshot ───────────────────────────────────────────────────────────
// Daily market prices fetched from Yahoo Finance (unofficial API, no auth).
// Covers VIX, S&P 500, Nasdaq, Russell 2000. Updated by macro_ingestion job.

model MarketSnapshot {
  id     Int      @id @default(autoincrement())
  date   DateTime // trading day (time portion zeroed)
  metric String   // "VIX" | "SP500" | "Nasdaq" | "Russell2000"
  value  Float
  source String   @default("Yahoo Finance")

  createdAt DateTime @default(now())

  @@unique([date, metric])
  @@index([metric])
  @@index([date])
  @@map("market_snapshots")
}

// ─── GeoEvent ────────────────────────────────────────────────────────────────
// Geopolitical news events classified by region and severity.
// Sourced from FMP general news endpoint, keyword-classified.

model GeoEvent {
  id              Int      @id @default(autoincrement())
  region          String   // "China/Taiwan" | "Middle East" | "Russia/Ukraine"
  eventTitle      String
  severity        String   // "low" | "medium" | "high" | "critical"
  affectedSectors String   @default("[]") // JSON: string[]
  source          String   // news publisher (e.g. "Reuters")
  sourceUrl       String?
  eventDate       DateTime

  createdAt DateTime @default(now())

  @@index([region])
  @@index([eventDate])
  @@map("geo_events")
}

// ─── CashFlow ─────────────────────────────────────────────────────────────────
// Explicit deposit / withdrawal record. Net deposits = sum of all cash flows.
// Source of truth for inception return calculation.

model CashFlow {
  id        String   @id @default(cuid())
  date      DateTime
  type      String   // "deposit" | "withdrawal"
  amountUsd Float
  note      String?
  source    String   @default("manual") // "manual" | "import"
  createdAt DateTime @default(now())

  @@index([date])
  @@map("cash_flows")
}

// ─── PortfolioSnapshot ────────────────────────────────────────────────────────
// Periodic mark-to-market. Mirrors Sheet2 of the Excel workbook plus TWR support.
// snapshotDate is unique — one snapshot per calendar day.

model PortfolioSnapshot {
  id               String   @id @default(cuid())
  snapshotDate     DateTime @unique
  portfolioValueUsd Float
  cashValueUsd     Float    @default(0)
  investedValueUsd Float    @default(0)
  netDepositsUsd   Float
  unrealizedGainUsd Float
  totalReturnPct   Float    // simple: gain / netDeposits × 100
  twrFactor        Float    @default(1.0) // sub-period return factor for TWR chain
  source           String   @default("manual") // "manual" | "auto" | "import"
  createdAt        DateTime @default(now())

  @@index([snapshotDate])
  @@map("portfolio_snapshots")
}
