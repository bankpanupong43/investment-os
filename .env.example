# Brain OS vault root — override auto-discovery (optional)
# If unset, resolved automatically: D:\Projects\shared\Brain OS → G:\...\Shared\Brain OS → ./brain-os
# BRAIN_OS_ROOT="D:\\Projects\\shared\\Brain OS"

# Database
DATABASE_URL="file:./dev.db"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# Financial Modeling Prep — free tier: 250 req/day
# Sign up at https://site.financialmodelingprep.com/
FMP_API_KEY=""

# Email delivery (nodemailer / Gmail SMTP)
# SMTP_HOST — e.g. smtp.gmail.com
# SMTP_PORT — 587 for STARTTLS (default), 465 for SSL
# SMTP_USER — sender Gmail address
# SMTP_PASS — Gmail App Password (16 chars, spaces optional — stripped automatically)
#              Generate at: https://myaccount.google.com/apppasswords
# EMAIL_TO  — recipient address for CIO briefs
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_TO=""

# Optional: news/market data APIs (for data-feeds phase)
# ALPHA_VANTAGE_API_KEY=""
# POLYGON_API_KEY=""
# NEWS_API_KEY=""
