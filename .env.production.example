# Database (Supabase PostgreSQL — direct connection for persistent server)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Market data
FMP_API_KEY=...
FRED_API_KEY=...

# Email (morning brief delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_TO=your@gmail.com

# Gmail OAuth (newsletter ingestion)
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REFRESH_TOKEN=...

# Brain OS wiki (Docker volume mount path)
BRAIN_OS_ROOT=/data/brain-os

# Cloudflare Tunnel token (for cloudflared container)
CF_TUNNEL_TOKEN=...

# Runtime
NODE_ENV=production
